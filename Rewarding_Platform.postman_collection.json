              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Cart data is returned\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.data).to.have.property(\"items\");",
                  "    pm.expect(json.data.items).to.be.an(\"array\");",
                  "    pm.expect(json.data).to.have.property(\"total\");",
                  "});",
                  "",
                  "pm.test(\"Cart items have required fields\", function () {",
                  "    var json = pm.response.json();",
                  "    if (json.data && json.data.items && json.data.items.length > 0) {",
                  "        json.data.items.forEach(function(item) {",
                  "            pm.expect(item).to.have.property(\"productId\");",
                  "            pm.expect(item).to.have.property(\"name\");",
                  "            pm.expect(item).to.have.property(\"price\");",
                  "            pm.expect(item).to.have.property(\"quantity\");",
                  "            pm.expect(item).to.have.property(\"subtotal\");",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
