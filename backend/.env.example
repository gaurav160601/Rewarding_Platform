# ── Environment ──
NODE_ENV=development
PORT=5000

# ── MySQL (TiDB Cloud) ──
MYSQL_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
MYSQL_PORT=4000
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=ecommerce

# ── MongoDB Atlas ──
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<app>

# ── Redis (Upstash) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── JWT ──
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7d

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Client URL (for Stripe success/cancel redirects) ──
CLIENT_URL=http://localhost:5173

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Resend (Email) ──
RESEND_API_KEY=
EMAIL_FROM=noreply@rewardingplatform.com

# ── Kafka (Aiven) ──
KAFKA_BROKER=
KAFKA_CLIENT_ID=rewarding-platform
KAFKA_SSL=true
KAFKA_CA_PATH=./certs/kafka.ca.pem
KAFKA_CERT_PATH=./certs/kafka.cert.pem
KAFKA_KEY_PATH=./certs/kafka.key.pem
# KAFKA_USERNAME=
# KAFKA_PASSWORD=
